# Copy this file to .env and fill in your values before deploying.
# Never commit .env to version control.

# REQUIRED: Long random secret key for session signing.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FFS_SECRET=change_me_to_a_long_random_secret

# REQUIRED: Salt used for PBKDF2 password hashing.
# Generate one with: python -c "import secrets; print(secrets.token_hex(16))"
FFS_SALT=change_me_to_a_random_salt

# Set to "1" when running behind HTTPS to enable:
#   - Secure cookie flag
#   - HSTS header
HTTPS=0

# Flask debug mode — MUST be "0" or unset in production
FLASK_DEBUG=0

# Port to listen on (default: 5000)
PORT=5000
